# Google Sheets API Configuration
# 1. Buat Google Sheet dengan 3 tab: locations, visits, visit_photos
# 2. Share sheet ke "Anyone with the link" (View)
# 3. Aktifkan Google Sheets API di Google Cloud Console
# 4. Buat API Key di Google Cloud Console

# Sheet ID - ambil dari URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
NEXT_PUBLIC_GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Sheets API Key
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_api_key_here
